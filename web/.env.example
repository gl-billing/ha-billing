# Google Cloud OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Guest preview OAuth — lets ANY Google account try the test lab (test-only sandbox).
# GOOGLE_GUEST_CLIENT_ID=
# GOOGLE_GUEST_CLIENT_SECRET=

# NextAuth — must match how you open the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Production (Vercel):
# NEXTAUTH_URL=https://ha-billing.vercel.app
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=

# Hernandez billing spreadsheet ID (from the URL)
GOOGLE_SPREADSHEET_ID=

# Blank templates — used by scripts/create-clean-workbooks.ts (never your live workbooks)
# Default GL structure-only templates if unset:
# https://docs.google.com/spreadsheets/d/1MFrcLDnLrmL7jmjcGU934-sd-udAZFzoKIYZ7NvKvf8/edit
GOOGLE_BILLING_TEMPLATE_SPREADSHEET_ID=
# https://docs.google.com/spreadsheets/d/1EeezyqT0AeimXz21iJyskXgUtibXzZ7qwoboPCC1at0/edit
GOOGLE_TASKS_TEMPLATE_SPREADSHEET_ID=
# Firm Google refresh token for create-clean-workbooks.ts (spreadsheets + drive.file scopes)
# CRON_GOOGLE_REFRESH_TOKEN=

# Restrict full Office Hub access to firm staff (comma-separated emails or domain).
ALLOWED_EMAIL_DOMAIN=
# Or explicit list (overrides domain if set):
ALLOWED_EMAILS=

# Official outbound email shown to clients (SOA, AR, payment requests, etc.)
FIRM_SENDER_EMAIL=info@hernandezassociates.com

# Letterhead / PDF contact lines (contracts, SOA, AR, correspondence)
# FIRM_ADDRESS=Your office address here
# FIRM_LANDLINE_PHONE=
# FIRM_MOBILE_PHONE=
# NEXT_PUBLIC_FIRM_MOBILE_PHONE=
# FIRM_WEBSITE=www.hernandezassociates.com

# Firm admins (comma-separated Google sign-in emails).
# ADMIN_EMAILS=

# Staff who must NOT open billing (tasks & calendar only).
# TASKS_ONLY_EMAILS=

# Apps Script Web App (for SOA / AR / PDF / Gmail)
APPS_SCRIPT_WEB_APP_URL=
APPS_SCRIPT_WEB_APP_SECRET=

# Vercel Cron
CRON_SECRET=

# Used for PWA metadata and desktop app config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Office Tasks spreadsheet (required for /app — separate from billing)
TASKS_GOOGLE_SPREADSHEET_ID=

# Tasks Apps Script (optional)
# TASKS_APPS_SCRIPT_WEB_APP_URL=
# TASKS_APPS_SCRIPT_WEB_APP_SECRET=

# Payment request links (/pay/...)
# PAYMENT_PAYEE_NAME=Hernandez & Associates Law Office
