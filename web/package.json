    "next-auth": "^4.24.11",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.51.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
